# Odysseus Bot Environment Variables
# Copy to .env and fill in your values

# Telegram Bot (get from BotFather)
TELEGRAM_BOT_TOKEN=your-token-here

# Telegram User (Denis only)
TELEGRAM_ALLOWED_USER_ID=147668366

# Odysseus API Server (inside container)
ODYSSEUS_API_HOST=localhost
ODYSSEUS_API_PORT=8888
ODYSSEUS_API_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
DEBUG=false

# Features
ENABLE_MESSAGE_FORWARDING=true
ENABLE_COMMAND_EXECUTION=false
MAX_LOG_LINES=100

# Timeouts
MESSAGE_TIMEOUT=30
STATUS_CHECK_INTERVAL=5
